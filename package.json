{
  "name": "mapago",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "ai:events": "tsx scripts/get-on-this-day.ts",
    "ai:coordinates": "tsx scripts/get-wikidata-coordinates.ts",
    "ai:populate": "tsx scripts/populate-daily-challenges.ts",
    "ai:views": "tsx scripts/get-wikipedia-views.ts",
    "ai:used-locations": "tsx scripts/get-used-locations.ts",
    "predeploy": "npm run build",
    "deploy": "npm run build && wrangler deploy",
    "lint": "eslint .",
    "preview": "npm run build && wrangler dev"
  },
  "dependencies": {
    "gh-pages": "^6.3.0",
    "leaflet": "^1.9.4",
    "leaflet.geodesic": "^2.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.3",
    "@eslint/js": "^9.39.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wrangler": "^4.90.0"
  }
}
